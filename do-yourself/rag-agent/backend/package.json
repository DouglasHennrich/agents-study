{
  "name": "rag-agent",
  "version": "1.0.0",
  "description": "RAG Agent with NestJS, pgvector and Ollama",
  "main": "dist/main.js",
  "scripts": {
    "check": "pnpm tsc --noEmit",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "migration:create": "typeorm migration:create src/@database/migrations/$npm_config_name",
    "migration:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d src/@database/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:revert -d src/@database/data-source.ts",
    "test:unit": "vitest run --exclude '**/*.e2e.spec.ts'",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.8",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.19",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "protobufjs"
    ]
  },
  "dependencies": {
    "@langchain/community": "^0.3.59",
    "@langchain/ollama": "^0.2.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "langchain": "^0.3.37",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.29",
    "zod": "^3.25.76"
  }
}